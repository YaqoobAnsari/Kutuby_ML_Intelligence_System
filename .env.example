# --- Supabase access (server-side only; no end-user auth) ---
# Copy this file to .env.local and fill in the values, or hardcode them in
# src/lib/supabase/config.ts.

# Supabase project URL
SUPABASE_URL=
# Supabase service role key (SECRET — bypasses RLS; server-side only, never shipped to the browser)
SUPABASE_SERVICE_ROLE_KEY=
# Private storage bucket holding the WAV pronunciation recordings
SUPABASE_STORAGE_BUCKET=pronunciation-recordings
# TTL (seconds) for server-minted signed audio URLs; must be <= 900
SIGNED_URL_TTL_SECONDS=900
